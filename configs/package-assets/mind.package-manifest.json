{
  "version": "1.1.0",
  "id": "mind",
  "scopes-declaration": [
    {
      "identifier": "mind.web",
      "name": "MIND Web Interface",
      "description": "Access to the MIND web application",
      "scopes": [
        {
          "identifier": "mind.web.r",
          "name": "Read",
          "description": "Read-only access to MIND"
        },
        {
          "identifier": "mind.web.rw",
          "name": "Read and Write",
          "description": "Full access to MIND"
        }
      ]
    }
  ],
  "services": {
    "proxyMapping": [
      {
        "name": "mind",
        "url": "/mind",
        "binding": "unix://{$SNAP_DATA}/package-run/mind/web.sock",
        "restricted": []
      }
    ]
  },
  "menus": {
    "sidebar": [
      {
        "id": "mind",
        "target": "_blank",
        "title": "MIND",
        "icon": "bosch-ic-worldwideweb",
        "link": "/mind?token=${bearertoken}"
      }
    ],
    "settings": [],
    "overview": [
      {
        "id": "mind",
        "title": "MIND",
        "icon": "bosch-ic-worldwideweb",
        "link": "/mind?token=${bearertoken}"
      }
    ]
  }
}
