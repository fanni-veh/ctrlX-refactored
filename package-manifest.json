{
  "version": "1.0.0",
  "id": "mind",
  "vendor": {
    "name": "Maxon Motor AG"
  },
  "title": "MIND",
  "description": "Motion Insights and Diagnostics — predictive maintenance for drive systems.",
  "scopes-declaration": [
    {
      "identifier": "mind.web",
      "name": "MIND Web Interface",
      "description": "Access to the MIND web application",
      "scopes": [
        {
          "identifier": "mind.web.r",
          "name": "Read",
          "description": "Read-only access to MIND"
        },
        {
          "identifier": "mind.web.rw",
          "name": "Read and Write",
          "description": "Full access to MIND"
        }
      ]
    }
  ],
  "services": {
    "proxyMapping": [
      {
        "name": "mind",
        "url": "/mind",
        "binding": "http://localhost:8000",
        "restricted": []
      }
    ]
  },
  "menus": {
    "sidebar": [
      {
        "id": "mind",
        "title": "MIND",
        "icon": "Bosch-Ic-chart-line",
        "link": "/mind/?token=${bearertoken}"
      }
    ],
    "settings": [],
    "overview": [
      {
        "id": "mind",
        "title": "MIND",
        "icon": "Bosch-Ic-chart-line",
        "link": "/mind/?token=${bearertoken}"
      }
    ]
  }
}
